# ============================================
# IDM-FME Production Environment Variables
# ============================================
# Copy this file to .env.production.local and fill in your values.
# These are required for Vercel deployment with Supabase.

# ─────────────────────────────────────────────
# Database — Supabase PostgreSQL
# ─────────────────────────────────────────────
# Connection-pooled URL (for application queries via Supavisor)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection URL (for migrations and Prisma Studio)
DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# ─────────────────────────────────────────────
# Supabase Storage Buckets
# ─────────────────────────────────────────────
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_PROOF_BUCKET=payment-proofs
SUPABASE_LOGO_BUCKET=club-logos

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=[random-secret-min-32-chars]

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=IDOL META Tournament
NEXT_PUBLIC_APP_URL=https://[your-vercel-domain].vercel.app

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
